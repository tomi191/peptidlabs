# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.local.example

# superpowers
.superpowers/

# claude code workspace (agents / skills / marketing drafts)
.claude/

# playwright MCP screenshots + snapshots
.playwright-mcp/

# root-level screenshots from local testing
/*.png

# internal docs / specs
docs/

# vercel
.vercel

# data dumps / contact lists — never commit user PII
/users-*.csv
/scripts/.tmp-*

# typescript
*.tsbuildinfo
next-env.d.ts
